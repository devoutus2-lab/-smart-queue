{
  "name": "smart-queue",
  "version": "0.1.0",
  "description": "Smart Queue desktop-ready queueing and appointment app.",
  "author": "Smart Queue",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "pkg": {
    "assets": [
      "dist/spa/*"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "start": "node dist/server/node-build.mjs",
    "desktop": "node scripts/desktop-run.mjs",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:pack": "node scripts/desktop-pack.mjs --dir",
    "desktop:dist": "node scripts/desktop-pack.mjs",
    "test": "vitest --run",
    "format.fix": "prettier --write .",
    "typecheck": "tsc",
    "db:sanitize": "node scripts/sanitize-db.mjs",
    "handoff": "npm run build && node scripts/create-handoff.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "call-bind-apply-helpers": "^1.0.2",
    "call-bound": "^1.0.4",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.45.1",
    "dunder-proto": "^1.0.1",
    "ee-first": "^1.1.1",
    "es-define-property": "^1.0.1",
    "es-errors": "^1.3.0",
    "es-object-atoms": "^1.1.1",
    "express": "^5.1.0",
    "function-bind": "^1.1.2",
    "get-intrinsic": "^1.3.0",
    "get-proto": "^1.0.1",
    "gopd": "^1.2.0",
    "has-symbols": "^1.1.0",
    "hasown": "^2.0.2",
    "leaflet": "^1.9.4",
    "math-intrinsics": "^1.1.0",
    "media-typer": "^1.1.0",
    "mime-db": "^1.54.0",
    "object-inspect": "^1.13.4",
    "react-leaflet": "^5.0.0",
    "setprototypeof": "^1.2.0",
    "side-channel": "^1.1.0",
    "side-channel-list": "^1.0.0",
    "side-channel-map": "^1.0.1",
    "side-channel-weakmap": "^1.0.2",
    "toidentifier": "^1.0.1",
    "wrappy": "^1.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@swc/core": "^1.13.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.84.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.2.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.539.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.smartqueue.desktop",
    "productName": "Smart Queue",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release-fresh"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/.git/**"
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "Smart-Queue-Setup-${version}.${ext}"
    }
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
