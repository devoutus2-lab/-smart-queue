# Copy this file to `.env` for local development.
# Keep real secrets out of version control.
# Desktop builds can also read `qtech.env` from the installed app folder
# or from the app-data directory after installation.

# Optional server port for the production bundle.
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1

# Optional public app URL used for absolute links and cookie security.
APP_URL=

# Optional message returned by GET /api/ping.
PING_MESSAGE=pong

# Optional override for the local SQLite data directory.
QTECH_DATA_DIR=.data

# Set to true only when you intentionally want demo/sample data inserted.
QTECH_ENABLE_DEMO_SEEDING=true

# Optional cookie settings for hosted HTTPS deployments.
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=

# Optional comma-separated list of allowed browser origins when not using same-origin hosting.
CORS_ALLOWED_ORIGINS=

# Planned shared cloud database connection string for the Postgres migration.
# The current checked-in runtime still uses SQLite until the Drizzle adapter migration is completed.
DATABASE_URL=

# Optional secret for admin self-registration.
ADMIN_SIGNUP_SECRET=change-me-before-sharing-admin-access

# Optional Groq assistant configuration.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional Google Places integration.
GOOGLE_PLACES_API_KEY=
